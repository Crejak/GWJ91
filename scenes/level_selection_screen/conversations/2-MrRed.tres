dialogs = Array[String](["You must know who Mr. Blue is, huh? He's the guy who owns most of the buildings in town.", "I had the misfortune of running into him yesterday at the casino... That son of a bitch cleaned me out!", "Everyone beats me at poker, but I can tell when the game's rigged. He definitely cheated!", "If you’ve got the guts, go see him tonight."])
