[layer_names]

2d_physics/layer_1="Environment"
2d_physics/layer_2="PlayerCharacter"
2d_physics/layer_3="Walls"
2d_physics/layer_4="Loot"
2d_physics/layer_5="Rooms"
2d_physics/layer_8="DoorBlocking"

[maaacks_game_template]

copy_path="res://"
disable_update_check=false
disable_install_wizard=true
disable_install_audio_busses=true

[physics]

2d/default_gravity=0.0
common/enable_pause_aware_picking=true

[rendering]

textures/canvas_textures/default_texture_filter=3
textures/canvas_textures/default_texture_repeat=1
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_2d=2
environment/defaults/default_environment="res://default_env.tres"
